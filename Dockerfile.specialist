FROM python:3.11-slim

WORKDIR /workspace

ENV SPECIALIST_APP_MODULE=services.remote_specialists.student_support.app:app

RUN apt-get update && apt-get install -y --no-install-recommends gcc && rm -rf /var/lib/apt/lists/*

COPY services/remote_specialists/requirements.txt services/remote_specialists/requirements.txt
RUN pip install --no-cache-dir -r services/remote_specialists/requirements.txt

COPY . .

CMD ["sh", "-c", "uvicorn ${SPECIALIST_APP_MODULE} --host 0.0.0.0 --port ${PORT:-8000}"]
