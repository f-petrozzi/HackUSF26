# CareMesh — environment variables
# Copy to apps/api/.env and fill in values

DATABASE_URL=postgresql+asyncpg://caremesh:caremesh@localhost:5432/caremesh
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Clerk auth
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_FRONTEND_API_URL=
CLERK_JWKS_URL=
CLERK_AUTHORIZED_PARTIES=http://localhost:8080

GEMINI_API_KEY=your-gemini-api-key-here

# Garmin (optional — app works in manual mode without this)
GARMIN_ENABLED=false
GARMIN_USERNAME=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password
GARMIN_TOKEN_DIR=./garmin_tokens
GARMIN_SYNC_INTERVAL_MIN=45
GARMIN_SYNC_DAYS_BACK=30

# Share this with teammates once backend is running
API_BASE_URL=http://localhost:8000

# Frontend auth (injected into the Vite app through Doppler)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
